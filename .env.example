# ===== Cau hinh Dify =====
# URL goc cua Dify (self-host thi thuong la http://localhost hoac http://localhost:80)
DIFY_BASE_URL=http://localhost

# API Key cua Knowledge Base (vao Dify > Knowledge > API > tao Secret Key, dang "dataset-...")
DIFY_API_KEY=dataset-xxxxxxxxxxxxxxxxxxxxxxxx

# ID cua Dataset (Knowledge Base) muon day file vao
DATASET_ID=your-dataset-id-here

# ===== Cau hinh quet thu muc =====
# Thu muc chua file khach hang can day len Dify
WATCH_FOLDER=e:/Dify/data_dangkiemViet

# Chu ky quet (giay). 300 = 5 phut, 3600 = 1 tieng
SCAN_INTERVAL=3600

# Cac duoi file duoc phep xu ly (cach nhau bang dau phay)
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.xlsx,.xls,.txt,.md,.csv,.html,.htm,.pptx,.ppt

# Cac duoi file coi la "text thuan" -> dung endpoint create-by-text
# Con lai dung create-by-file
TEXT_EXTENSIONS=.txt,.md,.csv,.html,.htm

# ===== Cau hinh xu ly cua Dify =====
# high_quality (dung embedding) hoac economy
INDEXING_TECHNIQUE=high_quality

# ===== OCR cho PDF scan =====
# true = tu dong nhan dien PDF scan (khong co lop text) va OCR truoc khi day len Dify.
# Yeu cau cai Tesseract OCR (kem goi tieng Viet 'vie') + Ghostscript tren may.
ENABLE_OCR=true
# Ngon ngu OCR: vie = tieng Viet; them +eng de doc them tieng Anh
OCR_LANGUAGES=vie+eng

# ===== Khac =====
# Duong dan file database SQLite
DB_PATH=./uploaded_files.db

# Muc log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
