# ===== Cau hinh Dify =====
DIFY_BASE_URL=http://localhost
DIFY_API_KEY=dataset-S473rg0mcN5nY8pwlq9KwGVM
DATASET_ID=03ddf0ae-3565-4960-b3cb-54b39de3f6cc

# ===== Cau hinh quet thu muc =====
WATCH_FOLDER=e:/Dify/data_dangkiemViet
SCAN_INTERVAL=3600
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.xlsx,.xls,.txt,.md,.csv,.html,.htm,.pptx,.ppt
TEXT_EXTENSIONS=.txt,.md,.csv,.html,.htm

# ===== Cau hinh xu ly cua Dify =====
INDEXING_TECHNIQUE=high_quality

# ===== OCR cho PDF scan =====
# true = tu dong OCR PDF scan (anh chup) truoc khi day. Can cai Tesseract + Ghostscript.
ENABLE_OCR=true
# Ngon ngu OCR. vie = tieng Viet, them +eng cho lan tieng Anh
OCR_LANGUAGES=vie+eng

# ===== Khac =====
DB_PATH=./uploaded_files.db
LOG_LEVEL=INFO
